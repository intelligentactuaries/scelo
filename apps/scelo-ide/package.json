{
  "name": "@ia/scelo-ide",
  "version": "0.1.1",
  "private": true,
  "description": "Scelo IDE — a downloadable desktop workbench for actuaries. Bundled Python + R + the IA actuarial stack, ready to run offline.",
  "homepage": "https://intelligentactuaries.com",
  "author": {
    "name": "Intelligent Actuaries",
    "email": "hello@intelligentactuaries.com"
  },
  "license": "LicenseRef-Scelo-IDE-1.0",
  "main": "dist/main.js",
  "scripts": {
    "build:renderer": "bun run --cwd ../web build && node -e \"const fs=require('fs');fs.rmSync('resources/renderer',{recursive:true,force:true});fs.cpSync('../web/dist','resources/renderer',{recursive:true})\"",
    "build:main": "tsc -p tsconfig.json",
    "build": "bun run build:renderer && bun run build:main",
    "bundle:runtime": "bash scripts/bundle-runtimes.sh",
    "dev": "bun run build:main && electron .",
    "dist:linux": "bun run build && electron-builder --linux AppImage deb",
    "dist:mac": "bun run build && electron-builder --mac dmg",
    "dist:win": "bun run build && electron-builder --win nsis",
    "smoke:pty": "node --experimental-strip-types scripts/smoke-pty.ts"
  },
  "dependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "@vscode/ripgrep": "^1.18.0",
    "electron-log": "^5.2.0",
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.0"
  }
}
