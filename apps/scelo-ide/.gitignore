# Compiled main + preload outputs
dist/

# electron-builder outputs (installers + unpacked dirs)
build/
!build/.gitkeep

# Renderer copy (regenerated from apps/web on every build)
resources/renderer/

# Bundled runtimes (regenerated by scripts/bundle-runtimes.sh; gigabytes per platform)
resources/runtime/
!resources/runtime/.gitkeep

# Local node_modules (workspace hoisted, but just in case)
node_modules/
